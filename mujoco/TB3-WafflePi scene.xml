<mujoco model="TB3-WafflePi scene">
  <include file="turtlebot3_waffle_pi.xml"/>

  <statistic center="0 0 0.4" extent="6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>

    <material name="ekf_lm_mat" rgba="0.8 0 0.9 1"/>
    <material name="true_robot_mat" rgba="0 0 1 1"/>
    <material name="ekf_robot_mat" rgba="0.8 0 0.9 1"/>
    <material name="gt_robot_mat" rgba="0.85 0.85 0.85 1"/>
    <material name="fov_mat" rgba="0 1 0 0.6"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- OBSTACLES_GO_HERE -->
    <!-- EST_LANDMARKS_GO_HERE -->

    <body name="true_robot_marker" mocap="true" pos="0 0 0.08">
      <geom type="sphere" size="0.07" material="true_robot_mat" contype="0" conaffinity="0"/>
    </body>

    <body name="ekf_robot_marker" mocap="true" pos="0 0 0.10">
      <geom type="sphere" size="0.06" material="ekf_robot_mat" contype="0" conaffinity="0"/>
    </body>

    <body name="gt_robot_marker" mocap="true" pos="0 0 0.12">
      <geom type="sphere" size="0.05" material="gt_robot_mat" contype="0" conaffinity="0"/>
    </body>

    <body name="fov_left_marker" mocap="true" pos="0 0 0.04">
      <geom type="sphere" size="0.04" material="fov_mat" contype="0" conaffinity="0"/>
    </body>

    <body name="fov_right_marker" mocap="true" pos="0 0 0.04">
      <geom type="sphere" size="0.04" material="fov_mat" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>